{# nginx_tls_enabled is set in tasks/main.yml from whether a Let's Encrypt cert exists. #}
{% if nginx_domains is defined %}
{% for domain in nginx_domains %}
{% if loop.index == 1 %}
##
# {{ domain }} - The main domain used in the app
##

{% if nginx_tls_enabled %}
server {
    listen 443 ssl;
{% if nginx_listen_ipv6 %}
    listen [::]:443 ssl;
{% endif %}

    server_name {{ domain }};

    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem; # managed by Certbot
    # ssl_protocols / ssl_prefer_server_ciphers are set globally in nginx.conf

{% include 'security-headers.conf.j2' %}

{% include 'app-locations.conf.j2' %}
}
{% endif %}

# HTTP: always serve the ACME challenge. Before a cert exists, serve the app over
# HTTP so the site works; once TLS is enabled, redirect everything to HTTPS.
server {
    listen 80;
{% if nginx_listen_ipv6 %}
    listen [::]:80;
{% endif %}

    server_name {{ domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ nginx_acme_webroot }};
        default_type "text/plain";
    }

{% if nginx_tls_enabled %}
    location / {
        return 301 https://$host$request_uri;
    }
{% else %}
{% include 'security-headers.conf.j2' %}

{% include 'app-locations.conf.j2' %}
{% endif %}
}
{% else %}
##
# {{ domain }} - Secondary domain that is redirected to the main domain
##

{% if nginx_tls_enabled %}
server {
    listen 443 ssl;
{% if nginx_listen_ipv6 %}
    listen [::]:443 ssl;
{% endif %}

    server_name {{ domain }};

    ssl_certificate /etc/letsencrypt/live/{{ nginx_domains | first }}/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_domains | first }}/privkey.pem; # managed by Certbot
    # ssl_protocols / ssl_prefer_server_ciphers are set globally in nginx.conf

    return 301 https://{{ nginx_domains | first }}$request_uri;
}
{% endif %}

server {
    listen 80;
{% if nginx_listen_ipv6 %}
    listen [::]:80;
{% endif %}

    server_name {{ domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ nginx_acme_webroot }};
        default_type "text/plain";
    }

    location / {
{% if nginx_tls_enabled %}
        return 301 https://{{ nginx_domains | first }}$request_uri;
{% else %}
        return 301 $scheme://{{ nginx_domains | first }}$request_uri;
{% endif %}
    }
}
{% endif %}

{% endfor %}
{% else %}
##
# Localhost
##

server {
    listen 80;
{% if nginx_listen_ipv6 %}
    listen [::]:80;
{% endif %}

    server_name _;

{% include 'app-locations.conf.j2' %}
}
{% endif %}
